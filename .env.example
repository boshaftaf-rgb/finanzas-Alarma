# Supabase — base de datos (Auth pospuesto en v1)
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# URL del proyecto (ej. https://xxxxxxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Clave pública anon — segura en frontend con RLS activo (Fase 3, Vercel)
SUPABASE_ANON_KEY=your-anon-key

# Clave service_role — SOLO worker Docker. Bypass RLS. Nunca en Vite ni Vercel.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Conexión directa PostgreSQL — solo para migraciones locales (scripts/apply_migrations.py)
# Dashboard → Project Settings → Database → Connection string → URI (modo Session)
DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Twelve Data — velas de mercado (plan free: 800 req/día, 8 req/min)
# -----------------------------------------------------------------------------
# Dashboard → API Keys
# https://twelvedata.com/account/api-keys

TWELVE_DATA_API_KEY=your-twelve-data-api-key

# -----------------------------------------------------------------------------
# Gmail SMTP — envío de emails de alerta
# -----------------------------------------------------------------------------
# Requiere 2FA en la cuenta Google y una App Password (16 caracteres):
# https://myaccount.google.com/apppasswords
#
# El remitente (SMTP_USER) es tu Gmail; no hace falta dominio propio.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Destinatario de alertas en v1 (un solo usuario — papá) hasta que exista auth
ALERT_RECIPIENT_EMAIL=destinatario@ejemplo.com

# -----------------------------------------------------------------------------
# Frontend (React + Vite) — Fase 3, deploy en Vercel
# -----------------------------------------------------------------------------
# Vite solo expone variables con prefijo VITE_ al bundle del navegador.
# Usa los mismos valores que SUPABASE_URL y SUPABASE_ANON_KEY.
# NO incluyas SUPABASE_SERVICE_ROLE_KEY aquí.

VITE_SUPABASE_URL=https://lgfkqehzozjingrfqnyt.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# UUID fijo de papá en v1 (opcional; default en seed.sql)
# VITE_V1_USER_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Vercel Cron (worker serverless) — solo en Vercel, nunca en VITE_*
# -----------------------------------------------------------------------------
# Secreto para autorizar /api/cron/evaluate (Vercel lo envía como Bearer)
CRON_SECRET=generate-a-long-random-string

# true = usar worker/fixtures/*.json (dev); false = Twelve Data en producción
WORKER_USE_FIXTURES=false
